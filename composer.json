{
  "name": "ideasonpurpose/wp-theme-addons",
  "description": "WordPress Block Editor add-ons — JavaScript blocks, utilities, and PHP components",
  "type": "library",
  "license": "ISC",
  "authors": [
    {
      "name": "Ideas On Purpose",
      "homepage": "https://www.ideasonpurpose.com/"
    }
  ],
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true,
    "platform": {
      "php": "8.4",
      "ext-intl": "0"
    }
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/ideasonpurpose/wp-related-posts"
    }
  ],
  "require": {
    "ideasonpurpose/wp-related-posts": "dev-main"
  },
  "autoload": {
    "psr-4": {
      "IdeasOnPurpose\\WP\\Theme\\Addons\\Block\\Variation\\Group\\LinkedGroup\\": "editor/Block/Variation/Group/LinkedGroup/",
      "IdeasOnPurpose\\WP\\Theme\\Addons\\Block\\Variation\\Query\\RelatedPostsQuery\\": "editor/Block/Variation/Query/RelatedPostsQuery/",
      "IdeasOnPurpose\\WP\\Theme\\Addons\\CssLocalProps\\": "CssLocalProps/"
    }
  }
}
